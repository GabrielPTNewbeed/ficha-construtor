# Environment Variables - Ficha Construtor

# Node Environment
NODE_ENV=development

# API Endpoints (se usar backend no futuro)
# VITE_API_URL=http://localhost:3000/api
# VITE_API_KEY=your_api_key_here

# Feature Flags
VITE_ENABLE_XCOM=true
VITE_ENABLE_DND5E=true
VITE_ENABLE_PREMIUM_THEMES=true

# Analytics (opcional)
# VITE_ANALYTICS_ID=your_analytics_id
